---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/books", label: "Books" },
  { href: "/royal-road", label: "Royal Road" },
  { href: "/updates", label: "Updates" },
  { href: "/newsletter", label: "Newsletter" },
  { href: "/contact", label: "Contact" },
];

const activePath = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<header class="sticky top-0 z-40 border-b border-slate-900/5 bg-white/90 backdrop-blur transition dark:border-slate-100/10 dark:bg-slate-950/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3">
      <span class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500 text-lg font-semibold text-white shadow-lg shadow-emerald-500/30">
        MP
      </span>
      <div>
        <p class="text-base font-semibold text-slate-900 dark:text-slate-100">Mike Parsons</p>
        <p class="text-sm text-slate-600 dark:text-slate-300">Mana Influx Progression Fantasy</p>
      </div>
    </a>
    <nav class="hidden items-center gap-1 text-sm font-medium text-slate-700 sm:flex dark:text-slate-300">
      {navItems.map((item) => {
        const normalized = item.href.replace(/\/+$/, "") || "/";
        const isActive =
          normalized === activePath || (normalized !== "/" && activePath.startsWith(normalized));
        return (
          <a
            href={item.href}
            class:list={[
              "rounded-full px-3 py-2 transition",
              isActive
                ? "bg-emerald-500 text-white shadow-inner shadow-emerald-600/50"
                : "hover:bg-emerald-100 hover:text-emerald-700 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-200",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <div class="flex items-center gap-3">
      <a
        class="hidden rounded-full bg-emerald-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400 sm:inline-flex"
        href="/newsletter"
      >
        Join Newsletter
      </a>
      <button
        id="mobile-nav-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-900/10 bg-white text-slate-700 transition hover:border-emerald-400 hover:text-emerald-500 sm:hidden dark:border-slate-100/10 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-emerald-400 dark:hover:text-emerald-200"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="sr-only">Toggle navigation</span>
        <svg class="h-6 w-6" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" fill="none">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
        </svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
  <nav
    id="mobile-nav"
    class="mobile-nav pointer-events-none block max-h-0 overflow-hidden border-t border-slate-900/5 bg-white transition-[max-height,opacity] duration-300 ease-in-out sm:hidden dark:border-slate-100/10 dark:bg-slate-950"
  >
    <div class="mx-auto max-w-6xl px-4 pb-6 pt-2">
      <ul class="flex flex-col gap-2 text-base font-medium text-slate-800 dark:text-slate-200">
        {navItems.map((item) => {
          const normalized = item.href.replace(/\/+$/, "") || "/";
          const isActive =
            normalized === activePath || (normalized !== "/" && activePath.startsWith(normalized));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block rounded-xl px-4 py-3 transition",
                  isActive
                    ? "bg-emerald-500 text-white shadow-inner"
                    : "bg-slate-100/80 hover:bg-emerald-100 dark:bg-slate-900/60 dark:hover:bg-emerald-500/20",
                ]}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
      <a
        class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-emerald-400"
        href="/newsletter"
      >
        Join Newsletter
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById("mobile-nav-toggle");
  const nav = document.getElementById("mobile-nav");
  if (toggle && nav) {
    const openIcon = `<svg class="h-6 w-6" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" fill="none"><path d="M6 6l12 12M6 18L18 6" stroke-linecap="round"/></svg>`;
    const closedIcon = `<svg class="h-6 w-6" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" fill="none"><path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/></svg>`;
    let open = false;

    const setState = (nextState) => {
      open = nextState;
      toggle.setAttribute("aria-expanded", String(open));
      nav.style.maxHeight = open ? `${nav.scrollHeight}px` : "0";
      nav.style.opacity = open ? "1" : "0";
      nav.classList.toggle("pointer-events-none", !open);
      toggle.innerHTML = open ? openIcon : closedIcon;
    };

    setState(false);

    toggle.addEventListener("click", () => {
      setState(!open);
    });
  }
</script>
