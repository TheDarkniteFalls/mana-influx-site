
---
import NewsletterForm from "../components/NewsletterForm.astro";
import ReviewQuote from "../components/ReviewQuote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadAuthor, loadSeries } from "../utils/content";

const author = await loadAuthor();
const seriesMap = await loadSeries();
const manaSeries = seriesMap["mana-influx"];
---

<BaseLayout title="About Mike Parsons">
  <section class="grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:items-center">
    <div class="relative">
      <div class="absolute -left-10 top-10 h-32 w-32 rounded-full bg-emerald-500/20 blur-3xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-3xl border border-emerald-500/20 bg-white shadow-lg dark:border-emerald-400/20 dark:bg-slate-900">
        <img
          src={author?.headshot ?? "/images/author/headshot-placeholder.svg"}
          alt={`Portrait of ${author?.name ?? "Mike Parsons"}`}
          class="h-full w-full object-cover"
        />
      </div>
    </div>
    <div class="space-y-6">
      <h1 class="text-3xl font-serif font-semibold text-slate-900 dark:text-slate-100">
        Meet Mike Parsons (aka Kiwi Parsons)
      </h1>
      <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300">
        {author?.shortBio ??
          "Mike Parsons writes the Mana Influx series, a LitRPG progression saga about survival after the mana storm. Chapters appear first on Royal Road under the pen name Kiwi Parsons, with Kindle Unlimited editions delivering polished arcs."}
      </p>
      <div class="space-y-4 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
        {(author?.longBio ?? "")
          .split("\n")
          .filter(Boolean)
          .map((paragraph) => (
            <p>{paragraph}</p>
          ))}
      </div>
      {author?.socials?.royalRoad && (
        <a
          href={author.socials.royalRoad}
          class="inline-flex items-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400"
          rel="noopener noreferrer"
        >
          Follow Kiwi Parsons on Royal Road
        </a>
      )}
    </div>
  </section>

  <section class="mt-12 grid gap-6 lg:grid-cols-3">
    <div class="rounded-3xl border border-slate-900/10 bg-white/80 p-6 text-sm leading-relaxed text-slate-600 shadow-sm dark:border-slate-100/10 dark:bg-slate-900/60 dark:text-slate-300">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Story-first systems</h2>
      <p class="mt-3">
        Bronwic’s build plays with mana physics, logistics expertise, and a storyteller’s improvisation. Expect crunchy skill trees that evolve with the story rather than strict dungeon grinds.
      </p>
    </div>
    <div class="rounded-3xl border border-slate-900/10 bg-white/80 p-6 text-sm leading-relaxed text-slate-600 shadow-sm dark:border-slate-100/10 dark:bg-slate-900/60 dark:text-slate-300">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Serial to polished pipeline</h2>
      <p class="mt-3">
        Draft chapters launch on Royal Road, reader feedback shapes revisions, and the final version releases to Kindle Unlimited, paperbacks, and audiobook narrators. Newsletter subscribers get progress breakdowns every step of the way.
      </p>
    </div>
    <div class="rounded-3xl border border-slate-900/10 bg-white/80 p-6 text-sm leading-relaxed text-slate-600 shadow-sm dark:border-slate-100/10 dark:bg-slate-900/60 dark:text-slate-300">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Community-driven</h2>
      <p class="mt-3">
        Discord check-ins, reader polls, and KU launch weeks keep the community involved. Mike credits readers for pushing the Mana Influx story to take bigger swings and explore new arcs.
      </p>
    </div>
  </section>

  <section class="mt-12 grid gap-6 lg:grid-cols-[1fr_0.8fr] lg:items-center">
    <NewsletterForm
      heading="Join the Mana Influx newsletter"
      description="Receive progress recaps, launch reminders, and bonus snippets. Unsubscribe anytime."
    />
    <ReviewQuote
      quote="The Mana Influx community helped me turn a retirement joke into a full-time saga. Thanks for reading, reviewing, and shouting about Bronwic."
      source="Mike Parsons"
      attribution="Author"
    />
  </section>
</BaseLayout>
