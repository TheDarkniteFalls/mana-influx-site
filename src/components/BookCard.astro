---
import type { CollectionEntry } from "astro:content";
import BookCTAButtons from "./BookCTAButtons.astro";

interface Props {
  book: CollectionEntry<"books">;
  showExcerpt?: boolean;
  highlightKu?: boolean;
}

const { book, showExcerpt = false, highlightKu = true } = Astro.props;
const { data } = book;
const coverAlt = `${data.title} cover art`;
const preview =
  data.blurb.length > 200
    ? `${data.blurb.slice(0, 197).trimEnd()}…`
    : data.blurb;
---

<article class="flex flex-col overflow-hidden rounded-3xl border border-slate-900/10 bg-white shadow-lg shadow-emerald-500/5 transition hover:border-emerald-500/40 dark:border-slate-100/10 dark:bg-slate-900">
  <div class="aspect-[3/4] bg-slate-200 dark:bg-slate-800">
    <img
      src={data.cover ?? "/images/books/placeholder.svg"}
      alt={coverAlt}
      loading="lazy"
      class="h-full w-full object-cover"
    />
  </div>
  <div class="flex flex-1 flex-col gap-4 p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        {data.seriesOrder && (
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-500">
            Book {data.seriesOrder}
          </p>
        )}
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100">{data.title}</h3>
        {data.subtitle && (
          <p class="text-sm text-slate-600 dark:text-slate-300">{data.subtitle}</p>
        )}
      </div>
      {highlightKu && data.kindleUnlimited && (
        <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-600 dark:text-emerald-300">
          Kindle Unlimited
        </span>
      )}
    </div>
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
      {showExcerpt ? data.blurb : preview}
    </p>
    <BookCTAButtons book={book} size="sm" />
  </div>
</article>
