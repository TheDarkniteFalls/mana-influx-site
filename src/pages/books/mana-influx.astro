---
import BookCard from "../../components/BookCard.astro";
import NewsletterForm from "../../components/NewsletterForm.astro";
import ReadingOrder from "../../components/ReadingOrder.astro";
import SeriesHero from "../../components/SeriesHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadBooks, loadSeries } from "../../utils/content";

const books = await loadBooks();
const seriesMap = await loadSeries();
const manaSeries = seriesMap["mana-influx"] ?? null;
const readingList = manaSeries?.data.readingOrder ?? books.map((book) => book.slug);
const orderedBooks = readingList
  .map((slug) => books.find((book) => book.slug === slug))
  .filter((book): book is (typeof books)[number] => Boolean(book));
const featuredBook = manaSeries?.data.featured
  ? books.find((book) => book.slug === manaSeries.data.featured)
  : books.find((book) => book.data.seriesOrder === 1) ?? books[0];
---

<BaseLayout title="Mana Influx Series" description={manaSeries?.data.description}>
  {manaSeries ? (
    <SeriesHero series={manaSeries} featuredBook={featuredBook} />
  ) : (
    <section class="rounded-3xl border border-emerald-500/20 bg-white/80 p-6 text-sm text-slate-600 shadow-sm dark:border-emerald-400/20 dark:bg-slate-900/60 dark:text-slate-300">
      <h1 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">Mana Influx Series</h1>
      <p class="mt-3">
        Series metadata will populate after running the content fetch script or updating
        <code class="mx-1 rounded bg-slate-200 px-1 py-0.5 text-xs text-slate-700 dark:bg-slate-800 dark:text-slate-200">
          src/content/series/mana-influx.json
        </code>
      </p>
    </section>
  )}

  <section class="mt-10 grid gap-10 lg:grid-cols-[1.3fr_1fr]">
    <div class="space-y-6">
      <ReadingOrder books={books} order={readingList} />
      <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
        The Mana Influx arc balances LitRPG crunch, progression power fantasy, and the cost of protecting a shattered
        Earth. Each book undergoes an additional edit pass before heading to Kindle Unlimited, so Newsletter subscribers
        receive both serial and polished release updates.
      </p>
    </div>
    <aside class="space-y-6 rounded-3xl border border-slate-900/10 bg-white/80 p-6 shadow-sm dark:border-slate-100/10 dark:bg-slate-900/60">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Release cadence</h3>
      <ul class="space-y-3 text-sm text-slate-600 dark:text-slate-300">
        <li>&bull; Serial chapters launch on Royal Road every week.</li>
        <li>&bull; New Kindle Unlimited titles drop quarterly, with KU exclusives replacing stubbed chapters.</li>
        <li>&bull; Audiobook and paperback announcements ship via the newsletter first.</li>
      </ul>
      <NewsletterForm
        heading="Get launch alerts"
        description="Weekly Royal Road updates and Kindle Unlimited release-day reminders."
      />
    </aside>
  </section>

  <section class="mt-12 space-y-6">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">All books in the series</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {orderedBooks.map((book) => (
        <BookCard book={book} showExcerpt />
      ))}
    </div>
  </section>
</BaseLayout>

