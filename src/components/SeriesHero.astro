---
import type { CollectionEntry } from "astro:content";
import BookCTAButtons from "./BookCTAButtons.astro";

interface Props {
  series: CollectionEntry<"series">;
  featuredBook?: CollectionEntry<"books">;
}

const { series, featuredBook } = Astro.props;
const { data } = series;
---

<section class="relative overflow-hidden rounded-3xl border border-emerald-500/30 bg-gradient-to-br from-slate-900 via-slate-800 to-emerald-800 px-6 py-12 text-white shadow-lg shadow-emerald-500/20 sm:px-12">
  <div class="grid gap-10 lg:grid-cols-2">
    <div class="max-w-xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-200">
        {data.tagline ?? "Mana Influx Series"}
      </p>
      <h1 class="text-3xl font-serif font-semibold sm:text-4xl">{data.title}</h1>
      <p class="text-base leading-relaxed text-slate-100/90">
        {data.description}
      </p>
      {data.highlights?.length && (
        <ul class="mt-4 grid gap-2 text-sm text-emerald-100 sm:grid-cols-2">
          {data.highlights.map((highlight) => (
            <li class="flex items-start gap-2">
              <span aria-hidden="true" class="mt-1 inline-flex h-2 w-2 rounded-full bg-emerald-300"></span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      )}
      {featuredBook && (
        <div class="mt-6 rounded-2xl border border-emerald-400/40 bg-slate-900/40 p-6 shadow-inner shadow-emerald-500/20">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-200">
            Featured release
          </p>
          <h2 class="mt-2 text-2xl font-semibold">{featuredBook.data.title}</h2>
          <p class="mt-3 text-sm text-slate-100/80">{featuredBook.data.blurb.slice(0, 220)}…</p>
          <div class="mt-4">
            <BookCTAButtons book={featuredBook} />
          </div>
        </div>
      )}
      {data.cta && (
        <div class="mt-6">
          <a
            href={data.cta.href}
            class="inline-flex items-center rounded-full bg-emerald-400 px-6 py-3 text-sm font-semibold text-slate-900 shadow-sm transition hover:bg-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-200"
          >
            {data.cta.label}
          </a>
        </div>
      )}
    </div>
    <div class="relative flex items-center justify-center">
      <div class="relative max-w-sm overflow-hidden rounded-3xl border border-emerald-400/30 bg-white/90 shadow-2xl shadow-emerald-500/20 dark:bg-slate-900">
        <div class="aspect-[3/4] bg-slate-200">
          <img
            src={featuredBook?.data.cover ?? data.cover ?? "/images/books/placeholder.svg"}
            alt={`${featuredBook?.data.title ?? data.title} cover art`}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
