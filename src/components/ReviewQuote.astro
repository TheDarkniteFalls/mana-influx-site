---
interface Props {
  quote: string;
  source?: string;
  attribution?: string;
}

const { quote, source, attribution } = Astro.props;
---

<figure class="rounded-3xl border border-emerald-500/20 bg-white p-6 shadow-lg shadow-emerald-500/10 dark:border-emerald-400/20 dark:bg-slate-900">
  <blockquote class="text-lg font-medium leading-relaxed text-slate-800 dark:text-slate-100">
    “{quote}”
  </blockquote>
  {(source || attribution) && (
    <figcaption class="mt-4 text-sm text-slate-500 dark:text-slate-300">
      {source && <span class="font-semibold text-slate-700 dark:text-slate-200">{source}</span>}
      {source && attribution && <span class="mx-2 text-slate-400">•</span>}
      {attribution}
    </figcaption>
  )}
</figure>
