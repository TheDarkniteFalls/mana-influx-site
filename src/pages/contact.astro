
---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadAuthor } from "../utils/content";

const author = await loadAuthor();
const formEndpoint =
  import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ??
  "https://formspree.io/f/mana-influx-placeholder";
---

<BaseLayout title="Contact">
  <section class="mx-auto flex w-full max-w-2xl flex-col gap-6">
    <h1 class="text-3xl font-serif font-semibold text-slate-900 dark:text-slate-100">
      Contact Mike Parsons
    </h1>
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
      Send questions about the Mana Influx series, collaboration requests, or media inquiries. For ARC or beta reader opportunities, join the newsletter and check the Updates page—those slots open to subscribers first.
    </p>
    <form
      class="space-y-4 rounded-3xl border border-slate-900/10 bg-white/90 p-6 shadow-sm dark:border-slate-100/10 dark:bg-slate-900/60"
      method="post"
      action={formEndpoint}
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
          Name
          <input
            type="text"
            name="name"
            required
            class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-400/50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
          />
        </label>
        <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
          Email
          <input
            type="email"
            name="email"
            required
            class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-400/50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
          />
        </label>
      </div>
      <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
        Topic
        <select
          name="topic"
          class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-400/50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
        >
          <option>General question</option>
          <option>Media / interview request</option>
          <option>Collaboration</option>
          <option>Merch / rights inquiry</option>
          <option>Other</option>
        </select>
      </label>
      <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
        Message
        <textarea
          name="message"
          required
          rows="6"
          class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-400/50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
        ></textarea>
      </label>
      <input type="hidden" name="_subject" value="Message from mparsonsauthor.com" />
      <div class="hidden">
        <label>
          Leave this empty:
          <input type="text" name="_honeypot" tabIndex="-1" autoComplete="off" />
        </label>
      </div>
      <button
        type="submit"
        class="inline-flex w-full items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-300"
      >
        Send message
      </button>
    </form>
    {author?.email && (
      <p class="text-xs text-slate-500 dark:text-slate-400">
        Prefer email? Reach out at <a class="text-emerald-600" href={`mailto:${author.email}`}>{author.email}</a>.
      </p>
    )}
  </section>
</BaseLayout>
