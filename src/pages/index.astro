
---
import BookCard from "../components/BookCard.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import ReviewQuote from "../components/ReviewQuote.astro";
import RoyalRoadPromo from "../components/RoyalRoadPromo.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  loadAuthor,
  loadBooks,
  loadSeries,
  loadUpdates,
} from "../utils/content";
import { formatDate } from "../utils/format";

const author = await loadAuthor();
const books = await loadBooks();
const seriesMap = await loadSeries();
const updates = await loadUpdates();

const manaSeries = seriesMap["mana-influx"];
const royalRoadSeries = seriesMap["royal-road"];
const featuredBook = manaSeries?.data.featured
  ? books.find((book) => book.slug === manaSeries.data.featured)
  : books.find((book) => book.data.seriesOrder === 1) ?? books[0];
const featuredDescription =
  featuredBook?.data.blurb ??
  "Discover the Mana Influx—an evolving LitRPG saga of survival, progression, and the price of power.";

const reviewHighlights = [
  {
    quote:
      "Crunchy systems, heartfelt stakes, and a main character you actually want to root for.",
    source: "Royal Road Reader",
    attribution: "@LitrpgAddict",
  },
  {
    quote:
      "Mana Influx feels like classic LitRPG wrapped in fresh worldbuilding. Bronwic's voice is addictive.",
    source: "Kindle Unlimited Review",
    attribution: "★★★★★",
  },
];

const latestUpdates = updates.slice(0, 3);
---

<BaseLayout title="Mana Influx LitRPG Series">
  <section class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:items-center">
    <div class="space-y-6">
      <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-600 dark:text-emerald-300">
        LitRPG • Progression Fantasy • Post-Apocalyptic Adventure
      </span>
      <h1 class="text-4xl font-serif font-semibold text-slate-900 sm:text-5xl dark:text-slate-100">
        The Mana Influx reshaped Earth. Bronwic plans to make sure humanity survives it.
      </h1>
      <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300">
        Join {author?.name ?? "Mike Parsons"} ({author?.penName ?? "Kiwi Parsons"}) as the Mana Influx series tracks
        Bronwic’s evolution from retired storyteller to humanity’s most unpredictable weapon. Serial chapters launch on
        Royal Road, polished arcs drop into Kindle Unlimited, and newsletters share the behind-the-scenes grind.
      </p>
      {featuredBook && (
        <div class="rounded-3xl border border-emerald-500/30 bg-white/80 p-6 shadow-xl shadow-emerald-500/10 dark:border-emerald-400/30 dark:bg-slate-900/70">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-500">Latest release</p>
          <h2 class="mt-2 text-2xl font-semibold text-slate-900 dark:text-slate-100">{featuredBook.data.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
            {featuredDescription}
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a
              href={`/book/${featuredBook.slug}`}
              class="inline-flex items-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-400/60"
            >
              View book page
            </a>
            <a
              href="/books/mana-influx"
              class="inline-flex items-center rounded-full border border-slate-900/10 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-emerald-400 hover:text-emerald-600 dark:border-slate-100/20 dark:text-slate-200"
            >
              Reading order
            </a>
          </div>
        </div>
      )}
      <NewsletterForm compact heading="Be first to know" />
    </div>
    <div class="relative">
      <div
        class="absolute inset-0 -translate-x-1/3 rounded-full bg-emerald-500/20 blur-3xl sm:-translate-x-1/2"
        aria-hidden="true"
      ></div>
      <div class="relative overflow-hidden rounded-[2.5rem] border border-emerald-500/30 bg-white shadow-2xl dark:bg-slate-900">
        <img
          src={featuredBook?.data.cover ?? "/images/books/placeholder.svg"}
          alt={`${featuredBook?.data.title ?? "Mana Influx"} cover art`}
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  {manaSeries && featuredBook && (
    <section class="space-y-6">
      <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">
        Discover the Mana Influx saga
      </h2>
      <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
        {manaSeries.data.description}
      </p>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {books.slice(0, 6).map((book) => (
          <BookCard book={book} />
        ))}
      </div>
    </section>
  )}

  {royalRoadSeries && <RoyalRoadPromo series={royalRoadSeries} />}

  <section class="grid gap-6 lg:grid-cols-3">
    {reviewHighlights.map((review) => (
      <ReviewQuote {...review} />
    ))}
  </section>

  {latestUpdates.length > 0 && (
    <section class="space-y-6">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">Latest updates</h2>
        <a
          href="/updates"
          class="text-sm font-semibold text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-300"
        >
          View all updates →
        </a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {latestUpdates.map((update) => (
          <article class="flex flex-col gap-3 rounded-2xl border border-slate-900/10 bg-white/90 p-5 shadow-sm transition hover:border-emerald-400 hover:shadow-md dark:border-slate-100/20 dark:bg-slate-900/60">
            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-500">
              {formatDate(update.data.date)}
            </p>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
              <a href={`/updates/${update.slug}`}>{update.data.title}</a>
            </h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">
              {update.body
                ? `${update.body.substring(0, 140).trim()}…`
                : update.data.excerpt ?? "Read the full update."}
            </p>
            <a
              href={`/updates/${update.slug}`}
              class="inline-flex items-center text-sm font-semibold text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-300"
            >
              Read update →
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
