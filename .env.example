# Mana Influx Author Site - Environment Variables
# Copy this file to .env and fill in your actual values

# Royal Road Integration
ROYALROAD_URL=https://www.royalroad.com/fiction/79360/the-mana-influx-a-post-apocalyptic-litrpg-adventure

# Amazon Integration (optional - for fetch script)
AMAZON_SERIES_URL=
AMAZON_ASSOC_TAG=

# Newsletter (ConvertKit)
PUBLIC_CONVERTKIT_FORM_ID=
CONVERTKIT_API_KEY=

# Analytics (Google Analytics 4)
GA_MEASUREMENT_ID=

# Contact Form (Formspree)
PUBLIC_FORMSPREE_ENDPOINT=

# Site Configuration
SITE_URL=https://mparsonsauthor.com
