---
interface Props {
  heading?: string;
  description?: string;
  compact?: boolean;
  successRedirect?: string;
}

const {
  heading = "Stay updated",
  description = "Quarterly release notes, launch day notifications, and behind-the-scenes progress reports.",
  compact = false,
  successRedirect = "/newsletter?subscribed=1",
} = Astro.props;

const formId = import.meta.env.PUBLIC_CONVERTKIT_FORM_ID ?? "";
const action = formId
  ? `https://app.convertkit.com/forms/${formId}/subscriptions`
  : "https://example.com/newsletter-placeholder";
---

<section class="rounded-2xl border border-emerald-500/30 bg-white/80 p-6 shadow-lg shadow-emerald-500/10 backdrop-blur-sm dark:border-emerald-400/30 dark:bg-slate-900/70 dark:shadow-none">
  <div class:list={["flex flex-col gap-4", compact ? "sm:flex-row sm:items-end sm:gap-6" : ""]}>
    <div class="flex-1">
      <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100">{heading}</h3>
      {!compact && <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{description}</p>}
    </div>
    <form
      action={action}
      method="post"
      class:list={[
        "flex w-full flex-col gap-3 sm:flex-row",
        compact ? "sm:items-center" : "",
      ]}
    >
      <input type="hidden" name="redirect" value={successRedirect} />
      <label class="flex-1">
        <span class="sr-only">Email address</span>
        <input
          required
          type="email"
          name="email_address"
          placeholder="you@example.com"
          class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-400/60 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
        />
      </label>
      <div class="hidden">
        <label>
          <span>Leave this field empty</span>
          <input type="text" name="hp" tabIndex="-1" autoComplete="off" />
        </label>
      </div>
      <button
        type="submit"
        class="inline-flex items-center justify-center rounded-xl bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-400/60"
      >
        Subscribe
      </button>
    </form>
  </div>
</section>
