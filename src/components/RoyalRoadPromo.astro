---
import type { CollectionEntry } from "astro:content";

interface Props {
  series: CollectionEntry<"series">;
}

const { series } = Astro.props;
const data = series.data;
---

<section class="overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-r from-emerald-500 via-emerald-600 to-emerald-400 p-1 shadow-lg shadow-emerald-500/20">
  <div class="grid gap-6 rounded-[21px] bg-white/95 p-8 sm:grid-cols-[2fr_1fr] dark:bg-slate-950/95">
    <div class="space-y-4">
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-600">
        Royal Road
      </p>
      <h2 class="text-2xl font-serif font-semibold text-slate-900">{data.title}</h2>
      <p class="text-sm text-slate-700 dark:text-slate-200">
        {data.description}
      </p>
      {data.highlights?.length && (
        <ul class="grid gap-2 text-sm text-slate-700 dark:text-slate-200 sm:grid-cols-2">
          {data.highlights.slice(0, 4).map((highlight) => (
            <li class="flex items-start gap-2">
              <span aria-hidden="true" class="mt-1 inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      )}
      <div class="flex flex-wrap gap-3">
        {data.cta && (
          <a
            href={data.cta.href}
            class="inline-flex items-center rounded-full bg-emerald-500 px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-300"
            rel="noopener noreferrer"
          >
            {data.cta.label}
          </a>
        )}
        <a
          href="/royal-road"
          class="inline-flex items-center rounded-full border border-slate-900/10 px-5 py-2 text-sm font-semibold text-slate-700 transition hover:border-emerald-400 hover:text-emerald-600 dark:border-slate-100/20 dark:text-slate-200"
        >
          Learn more
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="absolute inset-0 rounded-2xl bg-emerald-500/20 blur-3xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-2xl border border-emerald-500/40 shadow-lg shadow-emerald-500/30">
        <img
          src={data.cover ?? "/images/books/placeholder.svg"}
          alt={`${data.title} cover art`}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
